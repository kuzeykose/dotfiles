[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[http]
	postBuffer = 524288000
# Machine-specific identity (name, email, signing, etc.) lives in
# ~/.gitconfig.local and is NOT tracked here. See gitconfig.local.example
# for the template and setup instructions.
[include]
	path = ~/.gitconfig.local
